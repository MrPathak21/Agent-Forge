# Copy this file to .env and fill in your keys.

# OpenAI (required for AutoGen backend)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=   # optional — leave blank to use the default OpenAI endpoint

# Anthropic (required for Anthropic backend)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=

# Gemini (future)
GEMINI_API_KEY=
GEMINI_BASE_URL=
